<div id="<%= dom_id(contact, :email_activity) %>">
  <% if email_events.any? %>
    <div class="space-y-4">
      <% email_events.each do |send| %>
        <div class="border border-gray-200 rounded-lg p-4">
          <div class="flex justify-between items-start mb-2">
            <div>
              <h3 class="font-medium text-gray-900"><%= send.campaign.name %></h3>
              <p class="text-sm text-gray-600"><%= send.campaign_step&.email_template&.subject %></p>
            </div>
            <%= send_status_badge(send.status, extra_classes: "px-2 py-1 text-xs") %>
          </div>

          <div class="text-sm text-gray-500 mb-3">
            Sent <%= send.created_at.strftime("%B %d, %Y at %I:%M %p") %>
          </div>

          <% if send.email_events.any? %>
            <div class="border-l-2 border-indigo-200 pl-4 space-y-2">
              <% send.email_events.order(occurred_at: :asc).each do |event| %>
                <div class="flex items-start gap-2">
                  <div class="w-2 h-2 rounded-full <%= event.event_type == 'opened' ? 'bg-blue-500' : 'bg-green-500' %> mt-1"></div>
                  <div class="flex-1">
                    <div class="flex justify-between items-start">
                      <span class="text-sm font-medium capitalize text-gray-900"><%= event.event_type %></span>
                      <span class="text-xs text-gray-500"><%= event.occurred_at.strftime("%I:%M %p") %></span>
                    </div>
                    <% if event.url %>
                      <p class="text-xs text-gray-600 truncate"><%= event.url %></p>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-500 italic">No engagement yet</p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <p class="text-gray-500">No email activity yet for this contact.</p>
    </div>
  <% end %>
</div>

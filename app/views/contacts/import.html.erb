<div class="max-w-4xl mx-auto py-8 px-4">
  <h1 class="text-3xl font-bold text-gray-900 mb-6">Import Contacts</h1>
  
  <%= form_with url: process_import_organization_contacts_path(@organization), multipart: true, class: "space-y-6" do |form| %>
    <div class="bg-white shadow rounded-lg p-6">
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-2">CSV File</label>
        <%= form.file_field :csv_file, accept: ".csv", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100", required: true %>
        <p class="mt-1 text-sm text-gray-500">CSV should have columns: email, first_name, last_name</p>
      </div>
      
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-2">Tag Name (Optional)</label>
        <%= form.text_field :tag_name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: "e.g., legacy-customer" %>
        <p class="mt-1 text-sm text-gray-500">Apply this tag to all imported contacts</p>
      </div>
      
      <div>
        <%= form.submit "Import Contacts", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer" %>
      </div>
    </div>
  <% end %>
  
  <div class="mt-6">
    <%= link_to "Back to Contacts", organization_contacts_path(@organization), class: "text-indigo-600 hover:text-indigo-500" %>
  </div>
</div>

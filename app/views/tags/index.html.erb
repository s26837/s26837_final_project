<div class="max-w-7xl mx-auto py-8 px-4">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Tags</h1>
    <%= link_to "New Tag", new_organization_tag_path(@organization), class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700" %>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Color</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Contacts</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @tags.each do |tag| %>
          <tr>
            <td class="px-6 py-4 whitespace-nowrap">
              <%= tag_badge(tag) %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <div class="flex items-center gap-2">
                <div class="w-6 h-6 rounded border border-gray-300" style="background-color: <%= tag.display_color %>;"></div>
                <code class="text-xs"><%= tag.color || 'None' %></code>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
              <%= link_to tag.contacts.count, organization_contacts_path(@organization, tag_id: tag.id), class: "text-indigo-600 hover:text-indigo-900 font-medium" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= tag.created_at.strftime("%b %d, %Y") %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
              <%= link_to "Edit", edit_organization_tag_path(@organization, tag), class: "text-indigo-600 hover:text-indigo-900 mr-3" %>
              <%= link_to "Delete", organization_tag_path(@organization, tag), data: { turbo_method: :delete, turbo_confirm: "Are you sure? This will remove the tag from all contacts." }, class: "text-red-600 hover:text-red-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @tags.empty? %>
    <div class="text-center py-12 bg-white rounded-lg shadow mt-6">
      <p class="text-gray-500">No tags yet. <%= link_to "Create your first tag", new_organization_tag_path(@organization), class: "text-indigo-600 hover:text-indigo-500" %>.</p>
    </div>
  <% end %>
</div>

<div class="max-w-7xl mx-auto py-8 px-4">
  <div class="mb-6">
    <%= link_to "← Back to Campaigns", organization_campaigns_path(@organization), class: "text-indigo-600 hover:text-indigo-500" %>
  </div>

  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <div class="flex justify-between items-start">
      <div class="flex-1">
        <h1 class="text-3xl font-bold text-gray-900"><%= @campaign.name %></h1>
        <div class="flex gap-4 mt-4 items-center">
          <%= campaign_status_badge(@campaign.status, extra_classes: "px-3 py-1 text-sm") %>
          <% if @campaign.scheduled? && @campaign.scheduled_at %>
            <span class="text-sm text-blue-700">Scheduled for <%= @campaign.scheduled_at.strftime("%B %d, %Y at %I:%M %p %Z") %></span>
          <% end %>
          <% if @campaign.sent_at %>
            <span class="text-sm text-gray-500">Sent <%= @campaign.sent_at.strftime("%B %d, %Y at %I:%M %p") %></span>
          <% end %>
          <% if @projected_recipient_count %>
            <span class="text-sm text-gray-600">Targets <strong><%= @projected_recipient_count %></strong> contact<%= 's' if @projected_recipient_count != 1 %></span>
          <% end %>
        </div>
      </div>
      <div class="flex flex-col gap-2 items-end">
        <% if @campaign.status == 'draft' || @campaign.scheduled? %>
          <%= button_to "Send Now", send_now_organization_campaign_path(@organization, @campaign), method: :post, class: "px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700" %>
        <% end %>
        <% if @campaign.scheduled? %>
          <%= link_to "Edit schedule", edit_organization_campaign_path(@organization, @campaign), class: "text-sm text-indigo-600 hover:text-indigo-500" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Email Sequence</h2>
    <% if @campaign.steps.any? %>
      <ol class="space-y-2">
        <% @campaign.steps.each_with_index do |step, idx| %>
          <li class="flex items-center gap-3 p-2 border border-gray-200 rounded">
            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 text-xs font-semibold flex-shrink-0"><%= idx + 1 %></span>
            <div class="flex-1">
              <%= link_to step.email_template.name, organization_email_template_path(@organization, step.email_template), class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" %>
              <span class="text-xs text-gray-500 ml-2">Subject: <%= step.email_template.subject %></span>
            </div>
            <span class="text-xs text-gray-500 whitespace-nowrap">
              <% if idx == 0 %>
                <%= step.delay_hours.zero? ? "sends immediately" : "sends #{pluralize(step.delay_hours, 'hour')} after launch" %>
              <% else %>
                <%= step.delay_hours.zero? ? "sends right after previous" : "+#{pluralize(step.delay_hours, 'hour')} after previous" %>
              <% end %>
            </span>
          </li>
        <% end %>
      </ol>
    <% else %>
      <p class="text-sm text-gray-500">No emails configured for this campaign.</p>
    <% end %>
  </div>

  <%= turbo_stream_from "campaign_#{@campaign.id}" %>
  <%= render "stats_tiles", campaign: @campaign, stats: @stats %>

  <div class="bg-white shadow rounded-lg">
    <div class="px-6 py-4 border-b border-gray-200">
      <h2 class="text-lg font-medium text-gray-900">Recipients & Engagement</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Contact</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Sent At</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Engagement</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @sends.each do |send| %>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <div>
                    <div class="text-sm font-medium text-gray-900"><%= send.contact.full_name %></div>
                    <div class="text-sm text-gray-500"><%= send.contact.email %></div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <%= send_status_badge(send.status, extra_classes: "px-2 text-xs leading-5 rounded-full") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                <%= send.created_at.strftime("%b %d, %I:%M %p") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex gap-2">
                  <% if send.email_events.where(event_type: 'opened').any? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">
                      Opened (<%= send.email_events.where(event_type: 'opened').count %>)
                    </span>
                  <% end %>
                  <% if send.email_events.where(event_type: 'clicked').any? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-800">
                      Clicked (<%= send.email_events.where(event_type: 'clicked').count %>)
                    </span>
                  <% end %>
                  <% if send.email_events.empty? %>
                    <span class="text-xs text-gray-400">No activity</span>
                  <% end %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                <%= link_to "View Contact", organization_contact_path(@organization, send.contact), class: "text-indigo-600 hover:text-indigo-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <% if @sends.empty? %>
    <div class="text-center py-12 bg-white rounded-lg shadow mt-6">
      <p class="text-gray-500">No sends yet for this campaign.</p>
    </div>
  <% end %>
</div>

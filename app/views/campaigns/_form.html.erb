<%= form_with model: @campaign, url: form_url, class: "space-y-6" do |form| %>
  <% if @campaign.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded">
      <ul class="list-disc list-inside">
        <% @campaign.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white shadow rounded-lg p-6 space-y-4">
    <div>
      <%= form.label :name, "Campaign Name", class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name, placeholder: "e.g., Summer Promotion", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", autofocus: true %>
    </div>

    <div class="border-t border-gray-200 pt-4">
      <div class="flex justify-between items-center mb-2">
        <label class="block text-sm font-medium text-gray-700">Email Sequence</label>
        <%= link_to "+ New Template", new_organization_email_template_path(@organization), target: "_blank", class: "text-sm text-indigo-600 hover:text-indigo-500 font-medium" %>
      </div>
      <p class="text-xs text-gray-500 mb-3">Pick the templates to send, in order. Each step's <strong>delay</strong> is the wait in hours after the previous step (the first step's delay is measured from campaign launch).</p>

      <% if @templates.empty? %>
        <div class="bg-yellow-50 border border-yellow-200 rounded p-3 text-sm text-yellow-800">
          You need at least one email template before you can create a campaign.
          <%= link_to "Create a template", new_organization_email_template_path(@organization), class: "underline font-medium" %> to get started.
        </div>
      <% else %>
        <%
          existing_step_rows =
            if params.dig(:campaign, :steps).present?
              rows = params[:campaign][:steps]
              (rows.respond_to?(:values) ? rows.values : Array(rows)).map do |r|
                r = r.respond_to?(:to_unsafe_h) ? r.to_unsafe_h : r
                { email_template_id: r[:email_template_id] || r["email_template_id"], delay_hours: r[:delay_hours] || r["delay_hours"] }
              end
            else
              @campaign.steps.ordered.map { |s| { email_template_id: s.email_template_id, delay_hours: s.delay_hours } }
            end
          existing_step_rows = [{ email_template_id: nil, delay_hours: 0 }] if existing_step_rows.empty?
        %>

        <div id="campaign-steps" class="space-y-2">
          <% existing_step_rows.each_with_index do |row, idx| %>
            <div class="campaign-step flex items-center gap-2 bg-gray-50 border border-gray-200 rounded p-2" data-position="<%= idx %>">
              <span class="step-number inline-flex items-center justify-center w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 text-xs font-semibold flex-shrink-0"><%= idx + 1 %></span>
              <select name="campaign[steps][][email_template_id]" class="flex-1 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm">
                <option value="">Pick a template…</option>
                <%= options_from_collection_for_select(@templates, :id, :name, row[:email_template_id]) %>
              </select>
              <label class="text-xs text-gray-600 whitespace-nowrap">Delay (hrs)</label>
              <input type="number" min="0" name="campaign[steps][][delay_hours]" value="<%= row[:delay_hours].to_i %>" class="w-20 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm">
              <button type="button" class="remove-step text-gray-400 hover:text-red-600" aria-label="Remove step">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              </button>
            </div>
          <% end %>
        </div>

        <template id="campaign-step-template">
          <div class="campaign-step flex items-center gap-2 bg-gray-50 border border-gray-200 rounded p-2">
            <span class="step-number inline-flex items-center justify-center w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 text-xs font-semibold flex-shrink-0"></span>
            <select name="campaign[steps][][email_template_id]" class="flex-1 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm">
              <option value="">Pick a template</option>
              <%= options_from_collection_for_select(@templates, :id, :name) %>
            </select>
            <label class="text-xs text-gray-600 whitespace-nowrap">Delay (hrs)</label>
            <input type="number" min="0" name="campaign[steps][][delay_hours]" value="0" class="w-20 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm">
            <button type="button" class="remove-step text-gray-400 hover:text-red-600" aria-label="Remove step">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
          </div>
        </template>

        <button type="button" id="add-campaign-step" class="mt-3 inline-flex items-center gap-1 text-sm text-indigo-600 hover:text-indigo-500 font-medium">
          + Add another email
        </button>
      <% end %>
    </div>

    <div>
      <%= form.label "Send to Tags", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <% current_tag_ids = @campaign.campaign_tags.pluck(:tag_id) %>
      <% if @tags.any? %>
        <div class="grid grid-cols-2 gap-2">
          <% @tags.each do |tag| %>
            <label class="flex items-center">
              <%= check_box_tag 'tag_ids[]', tag.id, current_tag_ids.include?(tag.id), class: "h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" %>
              <span class="ml-2"><%= tag_badge(tag) %></span>
            </label>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-500">No tags yet. Create tags from the Contacts page.</p>
      <% end %>
    </div>

    <div class="border-t border-gray-200 pt-4">
      <label class="block text-sm font-medium text-gray-700 mb-2">Send to Specific Contacts</label>
      <%
        all_contacts = @organization.contacts.order(:email).limit(2000)
        selected_contact_ids = @campaign.campaign_contacts.map(&:contact_id).compact
      %>
      <div id="contact-picker">
        <input type="text" id="contact-search" placeholder="Search by name or email..." autocomplete="off"
               class="block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
        <ul id="contact-suggestions" class="hidden mt-1 max-h-48 overflow-y-auto bg-white border border-gray-200 rounded-md shadow-sm divide-y divide-gray-100"></ul>
        <div id="contact-selected" class="mt-3 flex flex-wrap gap-2"></div>
        <p class="mt-2 text-xs text-gray-500">Combine with tags above or use on its own. Leave both empty to send to <strong>all</strong> contacts.</p>
      </div>

      <script id="contact-data" type="application/json"><%= all_contacts.map { |c| { id: c.id, label: "#{c.full_name.presence || c.email} <#{c.email}>" } }.to_json.html_safe %></script>
      <script id="contact-preselected" type="application/json"><%= selected_contact_ids.to_json.html_safe %></script>
    </div>

    <% is_scheduled = @campaign.scheduled? && @campaign.scheduled_at.present? %>
    <div class="border-t border-gray-200 pt-4">
      <%= form.label "Delivery", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <div class="space-y-3">
        <label class="flex items-start gap-3">
          <input type="radio" name="send_mode" value="manual" <%= "checked" unless is_scheduled %>
                 onchange="document.getElementById('scheduled_at_field').classList.add('hidden'); document.getElementById('campaign_scheduled_at').value='';"
                 class="mt-1 h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300">
          <div>
            <span class="text-sm font-medium text-gray-900">Save as draft</span>
            <p class="text-xs text-gray-500">You'll click "Send Now" later from the campaign page.</p>
          </div>
        </label>
        <label class="flex items-start gap-3">
          <input type="radio" name="send_mode" value="scheduled" <%= "checked" if is_scheduled %>
                 onchange="document.getElementById('scheduled_at_field').classList.remove('hidden');"
                 class="mt-1 h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300">
          <div>
            <span class="text-sm font-medium text-gray-900">Schedule for later</span>
            <p class="text-xs text-gray-500">Sent automatically at the time you pick (UTC).</p>
          </div>
        </label>
      </div>

      <div id="scheduled_at_field" class="mt-4 <%= 'hidden' unless is_scheduled %>">
        <%= form.label :scheduled_at, "Send at", class: "block text-sm font-medium text-gray-700" %>
        <%= form.datetime_local_field :scheduled_at, value: @campaign.scheduled_at&.strftime("%Y-%m-%dT%H:%M"), min: Time.current.strftime("%Y-%m-%dT%H:%M"), class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
        <p class="mt-1 text-xs text-gray-500">Must be in the future.</p>
      </div>
    </div>

    <div>
      <%= form.submit submit_label, class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer" %>
    </div>
  </div>
<% end %>

<script>
  (function () {
    const root        = document.getElementById("contact-picker");
    if (!root) return;
    const input       = document.getElementById("contact-search");
    const suggestions = document.getElementById("contact-suggestions");
    const selectedBox = document.getElementById("contact-selected");
    const data        = JSON.parse(document.getElementById("contact-data").textContent || "[]");
    const preselected = JSON.parse(document.getElementById("contact-preselected").textContent || "[]");

    const selected = new Set(preselected.map((id) => parseInt(id)));

    function renderSelected() {
      selectedBox.innerHTML = "";
      if (selected.size === 0) {
        const empty = document.createElement("span");
        empty.className = "text-xs text-gray-400";
        empty.textContent = "No individual contacts selected.";
        selectedBox.appendChild(empty);
        return;
      }
      data.filter((c) => selected.has(c.id)).forEach((c) => {
        const chip = document.createElement("span");
        chip.className = "inline-flex items-center gap-1 px-2 py-1 rounded bg-indigo-100 text-indigo-800 text-xs";
        chip.innerHTML = `${c.label.replace(/[<>&]/g, (ch) => ({ '<':'&lt;', '>':'&gt;', '&':'&amp;'}[ch]))} <button type="button" data-remove="${c.id}" class="ml-1 text-indigo-600 hover:text-indigo-900">×</button>`;
        const hidden = document.createElement("input");
        hidden.type = "hidden"; hidden.name = "contact_ids[]"; hidden.value = c.id;
        chip.appendChild(hidden);
        selectedBox.appendChild(chip);
      });
    }

    function renderSuggestions(query) {
      const q = query.trim().toLowerCase();
      if (!q) { suggestions.classList.add("hidden"); suggestions.innerHTML = ""; return; }
      const matches = data
        .filter((c) => !selected.has(c.id))
        .filter((c) => c.label.toLowerCase().includes(q))
        .slice(0, 8);
      if (matches.length === 0) { suggestions.classList.add("hidden"); suggestions.innerHTML = ""; return; }
      suggestions.innerHTML = matches.map((c) => `<li class="px-3 py-2 text-sm hover:bg-indigo-50 cursor-pointer" data-add="${c.id}">${c.label.replace(/[<>&]/g, (ch) => ({ '<':'&lt;', '>':'&gt;', '&':'&amp;'}[ch]))}</li>`).join("");
      suggestions.classList.remove("hidden");
    }

    input.addEventListener("input", (e) => renderSuggestions(e.target.value));
    input.addEventListener("focus", (e) => renderSuggestions(e.target.value));
    document.addEventListener("click", (e) => {
      if (!root.contains(e.target)) suggestions.classList.add("hidden");
    });

    suggestions.addEventListener("click", (e) => {
      const li = e.target.closest("[data-add]");
      if (!li) return;
      selected.add(parseInt(li.dataset.add));
      input.value = "";
      suggestions.classList.add("hidden");
      renderSelected();
    });

    selectedBox.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-remove]");
      if (!btn) return;
      selected.delete(parseInt(btn.dataset.remove));
      renderSelected();
    });

    renderSelected();
  })();

  (function () {
    const list   = document.getElementById("campaign-steps");
    const addBtn = document.getElementById("add-campaign-step");
    const tmpl   = document.getElementById("campaign-step-template");
    if (!list || !addBtn || !tmpl) return;

    function renumber() {
      list.querySelectorAll(".campaign-step").forEach((row, i) => {
        row.dataset.position = i;
        const badge = row.querySelector(".step-number");
        if (badge) badge.textContent = i + 1;
      });
    }

    addBtn.addEventListener("click", () => {
      const row = tmpl.content.firstElementChild.cloneNode(true);
      list.appendChild(row);
      renumber();
    });

    list.addEventListener("click", (e) => {
      const btn = e.target.closest(".remove-step");
      if (!btn) return;
      const rows = list.querySelectorAll(".campaign-step");
      if (rows.length <= 1) return;
      btn.closest(".campaign-step").remove();
      renumber();
    });

    renumber();
  })();
</script>

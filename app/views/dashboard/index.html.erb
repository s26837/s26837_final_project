<div class="min-h-screen bg-gray-50">
  <% unless @organization.sendgrid_configured? %>
    <dialog id="sendgrid-jumpscare" class="rounded-xl shadow-2xl backdrop:bg-black/60 p-0 max-w-md w-[calc(100%-2rem)] m-auto">
      <div class="p-6">
        <div class="flex items-start gap-3 mb-4">
          <div class="flex-shrink-0 h-10 w-10 rounded-full bg-amber-100 flex items-center justify-center">
            <svg class="h-6 w-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-bold text-gray-900">SendGrid setup required</h2>
            <p class="text-sm text-gray-600 mt-1">Campaigns can't be delivered until your organization has a SendGrid API key. Add yours below, or use the shared demo key.</p>
          </div>
        </div>

        <%= form_with url: set_sendgrid_key_organization_path(@organization), method: :patch, local: true, class: "space-y-3" do |form| %>
          <div>
            <label for="sendgrid_api_key" class="block text-xs font-semibold uppercase tracking-wider text-gray-500 mb-1">Your SendGrid API key</label>
            <input type="password" name="sendgrid_api_key" id="sendgrid_api_key" placeholder="SG.xxxxxxxxxxxxxxxxxxxxxxxx"
                   class="block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 font-mono text-sm">
            <p class="text-xs text-gray-500 mt-1">Stored on your organization. You can change this later.</p>
          </div>
          <button type="submit" class="w-full px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-md hover:bg-indigo-700">Save key</button>
        <% end %>

        <div class="relative my-4">
          <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div>
          <div class="relative flex justify-center text-xs"><span class="bg-white px-2 text-gray-500">or</span></div>
        </div>

        <%= form_with url: set_sendgrid_key_organization_path(@organization), method: :patch, local: true do |form| %>
          <input type="hidden" name="use_demo" value="1">
          <button type="submit" class="w-full px-4 py-2 bg-gray-100 text-gray-800 text-sm font-semibold rounded-md hover:bg-gray-200 border border-gray-300">
            Use demo key
          </button>
        <% end %>

        <p class="text-xs text-gray-400 text-center mt-3">The demo key is shared across all demo organizations and rate-limited.</p>
      </div>
    </dialog>

    <script>
      (function () {
        const dlg = document.getElementById("sendgrid-jumpscare");
        if (!dlg || dlg.open) return;
        if (typeof dlg.showModal === "function") {
          dlg.showModal();
        } else {
          dlg.setAttribute("open", "");
        }
      })();
    </script>
  <% end %>

  <main class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
    <div class="mb-10">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-4">Quick Actions</h2>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <%= link_to import_organization_contacts_path(@organization), class: "group relative flex items-center space-x-4 rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition-all hover:border-indigo-500 hover:ring-1 hover:ring-indigo-500" do %>
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-indigo-50 text-indigo-600 group-hover:bg-indigo-600 group-hover:text-white transition-colors">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-900">Import Contacts</p>
            <p class="text-xs text-gray-500">Upload CSV or XLSX</p>
          </div>
        <% end %>

        <%= link_to new_organization_email_template_path(@organization), class: "group relative flex items-center space-x-4 rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition-all hover:border-indigo-500 hover:ring-1 hover:ring-indigo-500" do %>
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-emerald-50 text-emerald-600 group-hover:bg-emerald-600 group-hover:text-white transition-colors">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-900">Create Template</p>
            <p class="text-xs text-gray-500">Design a new email</p>
          </div>
        <% end %>

        <%= link_to new_organization_campaign_path(@organization), class: "group relative flex items-center space-x-4 rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition-all hover:border-indigo-500 hover:ring-1 hover:ring-indigo-500" do %>
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-blue-50 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-colors">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-900">Send Campaign</p>
            <p class="text-xs text-gray-500">Reach your audience</p>
          </div>
        <% end %>

        <%= link_to organization_members_path(@organization), class: "group relative flex items-center space-x-4 rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition-all hover:border-indigo-500 hover:ring-1 hover:ring-indigo-500" do %>
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-purple-50 text-purple-600 group-hover:bg-purple-600 group-hover:text-white transition-colors">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM3 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 019.374 21c-2.331 0-4.512-.645-6.374-1.766z" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-gray-900">Invite Team</p>
            <p class="text-xs text-gray-500">Add more members</p>
          </div>
        <% end %>
      </div>
    </div>

    <div class="overflow-hidden rounded-xl border border-gray-200 shadow-sm mb-10">
      <dl class="grid grid-cols-1 gap-px bg-gray-200 sm:grid-cols-2 lg:grid-cols-4">
        <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-2 bg-white px-6 py-8">
          <dt class="text-sm font-medium text-gray-500">Total Contacts</dt>
          <dd class="w-full flex-none text-3xl font-bold tracking-tight text-gray-900"><%= @contact_count %></dd>
        </div>
        <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-2 bg-white px-6 py-8">
          <dt class="text-sm font-medium text-gray-500">Email Templates</dt>
          <dd class="w-full flex-none text-3xl font-bold tracking-tight text-gray-900"><%= @template_count %></dd>
        </div>
        <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-2 bg-white px-6 py-8">
          <dt class="text-sm font-medium text-gray-500">Total Sent</dt>
          <dd class="w-full flex-none text-3xl font-bold tracking-tight text-gray-900"><%= @total_sent %></dd>
        </div>
        <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-2 bg-white px-6 py-8">
          <dt class="text-sm font-medium text-gray-500">Open Rate</dt>
          <dd class="text-xs font-semibold text-emerald-600">+2.1%</dd>
          <dd class="w-full flex-none text-3xl font-bold tracking-tight text-gray-900">
            <%= @total_sent > 0 ? "#{((@total_opens.to_f / @total_sent) * 100).round(1)}%" : "0%" %>
          </dd>
        </div>
      </dl>
    </div>

    <div class="bg-white shadow-sm border border-gray-200 rounded-xl overflow-hidden">
      <div class="px-6 py-5 border-b border-gray-200 flex justify-between items-center">
        <h2 class="text-lg font-bold text-gray-900">Recent Contacts</h2>
        <%= link_to "View all", organization_contacts_path(@organization), class: "text-sm font-semibold text-indigo-600 hover:text-indigo-500" %>
      </div>

      <% if @recent_contacts.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Contact</th>
              <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Added</th>
            </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
            <% @recent_contacts.each do |contact| %>
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="h-8 w-8 rounded-full bg-gray-100 flex items-center justify-center text-xs font-medium text-gray-600">
                      <%= contact.first_name[0] %><%= contact.last_name[0] %>
                    </div>
                    <div class="ml-3">
                      <div class="text-sm font-semibold text-gray-900"><%= contact.first_name %> <%= contact.last_name %></div>
                      <div class="text-xs text-gray-500"><%= contact.email %></div>
                    </div>
                  </div>
                </td>

                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                  <%= contact.created_at.strftime("%b %d, %Y") %>
                </td>
              </tr>
            <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="p-12 text-center">
          <p class="text-gray-500">No contacts yet. <%= link_to "Import contacts", import_organization_contacts_path(@organization), class: "text-indigo-600 font-semibold" %> to get started.</p>
        </div>
      <% end %>
    </div>
  </main>
</div>
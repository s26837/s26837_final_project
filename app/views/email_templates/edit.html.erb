<div class="max-w-6xl mx-auto py-8 px-4">
  <h1 class="text-3xl font-bold text-gray-900 mb-6">Edit Email Template</h1>

  <%= render "form",
        form_url: organization_email_template_path(@organization, @template),
        submit_label: "Update Template" %>

  <div class="mt-6">
    <%= link_to "Back to Templates", organization_email_templates_path(@organization), class: "text-indigo-600 hover:text-indigo-500" %>
  </div>
</div>
